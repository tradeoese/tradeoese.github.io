<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; background: black; overflow: hidden; }
        #game { width: 100%; height: 100vh; }
    </style>
</head>
<body>
    <div id="game"></div>
    <script>
        const params = new URLSearchParams(window.location.search);
        let core = params.get('core');
        let rom = params.get('rom');

        // Correction automatique du moteur pour Master System
        if (core === 'sms') {
            core = 'genesis_plus_gx';
        }

        window.EJS_player = '#game';
        window.EJS_core = core;
        window.EJS_gameUrl = rom;
        window.EJS_startOnLoaded = true;

        // Force le chargement des données depuis un serveur externe fiable
        window.EJS_pathtodata = "https://cdn.jsdelivr.net/gh/EmulatorJS/EmulatorJS@latest/data/";
    </script>
    <script src="https://cdn.jsdelivr.net/gh/EmulatorJS/EmulatorJS@latest/data/loader.js"></script>
</body>
</html>
